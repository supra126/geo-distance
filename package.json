{
  "name": "@simoko/geo-distance",
  "type": "module",
  "version": "0.1.0",
  "description": "geo distance calculation",
  "author": "Supra <supra126@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/supra126/geo-distance.git"
  },
  "bugs": "https://github.com/supra126/geo-distance/issues",
  "keywords": [
    "geo",
    "distance",
    "haversine",
    "coordinates"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepublishOnly": "npm run build",
    "release": "npm version patch && npm publish",
    "start": "tsx src/index.ts",
    "test": "vitest",
    "docs": "npm -C docs run dev",
    "docs:build": "npm -C docs run build",
    "docs:preview": "npm -C docs run preview",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
